# -----------------------------------------------------------------------------
# Shared application settings
# -----------------------------------------------------------------------------
APP_NAME=mm-rag-demo
APP_HOST=0.0.0.0
APP_PORT=8080
TIMEZONE=Asia/Seoul

AUTH_PROVIDER=github
GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=
GITHUB_AUTHORIZE_URL=https://github.com/login/oauth/authorize
GITHUB_ACCESS_TOKEN_URL=https://github.com/login/oauth/access_token
GITHUB_USER_API_URL=https://api.github.com/user

SESSION_COOKIE_NAME=mm_rag_demo_session
SESSION_COOKIE_SAMESITE=lax
# Starlette session cookies are always HttpOnly with the current middleware.
SESSION_COOKIE_HTTPONLY=true

INGEST_MAX_FILE_MB=100
INGEST_MAX_PAGES=500
INGEST_MAX_ATTEMPTS=3
INGEST_WORKER_POLL_SECONDS=2
INGEST_BATCH_PAGE_SIZE=8
OCR_ENABLED=true

RAG_DEFAULT_TOP_K=12
RAG_DEFAULT_RERANK_ENABLED=true
RAG_DEFAULT_RERANK_TOP_N=6
RAG_DEFAULT_MAX_IMAGES_TO_LLM=6
RAG_DEFAULT_RETRIEVAL_MODE=with_neighbors
RAG_DEFAULT_NEIGHBOR_WINDOW_N=1

OTEL_ENABLED=true
OTEL_SERVICE_NAME=mm-rag-demo
OTEL_EXPORTER_OTLP_ENDPOINT=
LOG_LEVEL=INFO
LOG_JSON=true

# -----------------------------------------------------------------------------
# Development profile (validated locally)
# Copy this file to `.env`, then keep these values for local/simple-demo usage.
# -----------------------------------------------------------------------------
APP_ENV=local
APP_DEBUG=false
SECRET_KEY=local-dev-change-me

# Set to true only when you want to skip GitHub OAuth locally.
AUTH_BYPASS=false
SESSION_COOKIE_SECURE=false

DB_BACKEND=sqlite
SQLITE_PATH=./data/app.db

OBJECT_STORE_BACKEND=filesystem
FILESYSTEM_STORAGE_ROOT=./data

VECTOR_BACKEND=nano
NANO_VECTOR_PATH=./data/vector_store

# Leave model settings empty to use deterministic local fallback behavior.
# OpenRouter embeddings can use either EMBEDDING_* or OPENROUTER_* aliases.
EMBEDDING_API_BASE=
EMBEDDING_API_KEY=
EMBEDDING_MODEL=
# OPENROUTER_API_BASE=https://openrouter.ai/api/v1
# OPENROUTER_API_KEY=
# OPENROUTER_MODEL=
RERANKER_API_BASE=
RERANKER_API_KEY=
RERANKER_MODEL=
LLM_API_BASE=
LLM_API_KEY=
LLM_MODEL=

# -----------------------------------------------------------------------------
# Production profile overrides (implemented, but still under validation)
# Replace the local values above before any shared or production deployment.
# -----------------------------------------------------------------------------
# APP_ENV=production
# APP_DEBUG=false
# SECRET_KEY=replace-with-a-long-random-secret
# AUTH_BYPASS=false
# SESSION_COOKIE_SECURE=true
#
# DB_BACKEND=mysql
# MYSQL_HOST=
# MYSQL_PORT=3306
# MYSQL_DB=
# MYSQL_USER=
# MYSQL_PASSWORD=
#
# OBJECT_STORE_BACKEND=s3
# S3_ENDPOINT=
# S3_BUCKET=
# S3_ACCESS_KEY=
# S3_SECRET_KEY=
# S3_REGION=
# S3_FORCE_PATH_STYLE=true
#
# VECTOR_BACKEND=elasticsearch
# ES_HOST=
# ES_USERNAME=
# ES_PASSWORD=
# ES_INDEX_PREFIX=mm_rag_demo
#
# EMBEDDING_API_BASE=
# EMBEDDING_API_KEY=
# EMBEDDING_MODEL=
# RERANKER_API_BASE=
# RERANKER_API_KEY=
# RERANKER_MODEL=
# LLM_API_BASE=
# LLM_API_KEY=
# LLM_MODEL=
